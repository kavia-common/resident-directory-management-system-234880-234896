# Public API base URL (browser-visible). Must point to backend_fastapi.
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Optional aliases used by code
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Healthcheck path (frontend will call `${NEXT_PUBLIC_API_BASE}${NEXT_PUBLIC_HEALTHCHECK_PATH}`)
NEXT_PUBLIC_HEALTHCHECK_PATH=/healthz

# Optional WebSocket URL (future use)
NEXT_PUBLIC_WS_URL=
